{
  "name": "partagpu",
  "version": "0.1.0",
  "description": "Application de partage de ressources de calcul (CPU/GPU/RAM) sur réseau local",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "cargo build -p partagpu-helper --manifest-path src-tauri/helper/Cargo.toml && tauri dev",
    "tauri:build": "cargo build -p partagpu-helper --release --manifest-path src-tauri/helper/Cargo.toml && tauri build",
    "helper:build": "cargo build -p partagpu-helper --manifest-path src-tauri/helper/Cargo.toml",
    "helper:build:release": "cargo build -p partagpu-helper --release --manifest-path src-tauri/helper/Cargo.toml",
    "setup": "sudo bash scripts/install-helper.sh",
    "setup:uninstall": "sudo bash scripts/uninstall-helper.sh",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "clean": "rm -rf dist node_modules src-tauri/target",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.30.0",
    "@typescript-eslint/parser": "^8.30.0",
    "@vitejs/plugin-react": "^4.4.0",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  }
}
