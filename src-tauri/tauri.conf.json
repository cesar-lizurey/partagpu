{
  "$schema": "https://raw.githubusercontent.com/nickolay/tauri-docs-en/refs/heads/next/references/config-schema.json",
  "productName": "PartaGPU",
  "version": "1.0.0",
  "identifier": "com.partagpu.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PartaGPU — Partage de ressources",
        "width": 960,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/com.partagpu.policy"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["policykit-1"],
        "desktopTemplate": null,
        "postInstallScript": "scripts/postinstall.sh"
      }
    }
  }
}
